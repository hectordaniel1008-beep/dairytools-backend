# ── Base de Datos PostgreSQL ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dairytools
DB_USER=postgres
DB_PASS=tu_password

# ── JWT ───────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_una_clave_secreta_muy_larga
JWT_ACCESS_EXPIRES=15m

JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_secreta_diferente
JWT_REFRESH_EXPIRES=7d

# ── App ───────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
